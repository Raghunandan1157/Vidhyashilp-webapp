{
    "rewrites": [
        { "source": "/", "destination": "/app.html" },
        { "source": "/about", "destination": "/app.html" },
        { "source": "/academics", "destination": "/app.html" },
        { "source": "/admissions", "destination": "/app.html" },
        { "source": "/infrastructure", "destination": "/app.html" },
        { "source": "/contact", "destination": "/app.html" }
    ],
    "headers": [
        {
            "source": "/images/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/pages/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=3600" }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=3600" }
            ]
        }
    ]
}
